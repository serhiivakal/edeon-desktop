{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Edeon Desktop",
  "version": "0.1.0",
  "identifier": "com.edeon.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Edeon Desktop",
        "width": 1280,
        "height": 880,
        "resizable": true,
        "minWidth": 1024,
        "minHeight": 700,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://files.rcsb.org https://*.rcsb.org; img-src 'self' data: blob:; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; worker-src 'self' blob:;"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}